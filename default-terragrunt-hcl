terraform {
  source = "tfr:///terraform-aws-modules/vpc/aws?version=${include.root.locals.terraform_module_versions.XXX}"
}

include "root" {
  path = find_in_parent_folders("root.hcl")
  expose = true

}

#easy reading of variables
locals {
  region      = include.root.locals.def.region
  rgn         = include.root.locals.def.rgn
  env         = include.root.locals.def.env
  name        = basename(get_terragrunt_dir())

  additional_tags = { }
}

inputs = {

  name = "ds-${local.region}-${local.name}-${local.env}"

  tags = merge( include.root.locals.default_tags, local.additional_tags )

}
